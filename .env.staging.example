# ---------------------------------------------------------------------------
# Template dla lokalnego stagingu. Skopiuj do .env.staging i uzupełnij wartości.
#   cp .env.staging.example .env.staging
#
# WAŻNE: .env.staging jest gitignored (zawiera sekrety dopasowane do proda).
#
# Jak to wypełnić:
#   1. Skopiuj ten plik jako .env.staging
#   2. IP_HASH_SECRET + IP_HASH_SALT skopiuj IDENTYCZNE z prod .env (żeby hashe
#      w snapshocie DB się zgadzały — inaczej tracking wygląda bez sensu)
#   3. DB_PASSWORD — dowolne, lokalne (nie musi być to samo co na prodzie;
#      pg_restore ustawia hasło z tego env przy pierwszym up)
#   4. NEXTAUTH_SECRET — dowolne, lokalne (wylogowanie po pull snapshotu OK)
#   5. NEXTAUTH_URL — zmień 192.168.x.x na Twoje LAN IP (sprawdź: ipconfig)
#   6. SMTP_* zostaw jako invalid.localhost — staging NIE wysyła maili klientom
# ---------------------------------------------------------------------------

# --- Baza ---
DB_PASSWORD=staging_local_password_change_me

# --- NextAuth ---
NEXTAUTH_SECRET=some_local_secret_doesnt_matter
NEXTAUTH_URL=http://192.168.1.67:3001

# --- IP hashing (MUSI pasować do proda, żeby snapshot miał sens) ---
IP_HASH_SECRET=copy_from_prod_env
IP_HASH_SALT=copy_from_prod_env

# --- SMTP — CELOWO WYŁĄCZONE ---
# Staging nie może wysyłać maili (kontakty klientów w snapshocie = prawdziwe).
# invalid.localhost nie istnieje → nodemailer fails → error w logach zamiast maila
SMTP_HOST=invalid.localhost
SMTP_PORT=465
SMTP_USER=disabled
SMTP_PASS=disabled
CONTACT_EMAIL=test@localhost

# --- Build metadata (puste = rolling-deploy.sh by wypełnił, lokalnie nie musi) ---
BUILD_COMMIT=staging-local
BUILD_BRANCH=staging-local
BUILD_TIME=staging-local

# --- Admin credentials (używane tylko przy pierwszym starcie profilu setup) ---
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=change_me_local_only
